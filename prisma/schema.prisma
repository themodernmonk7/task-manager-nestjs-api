// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat    = "cjs"
}

datasource db {

  provider = "sqlite"

}


model User {
  id    Int     @default(autoincrement()) @id
  name  String
  email String  @unique
  password String
  updated_at DateTime @updatedAt
  created_at DateTime @default(now())
}